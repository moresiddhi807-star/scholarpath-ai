# =========================================
# ScholarPath AI — Backend Environment Vars
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` file.
# =========================================

# ---- Database (MySQL) ----
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://scholarpath_user:change_me@localhost:3306/scholarpath_ai

# ---- JWT Authentication ----
# Generate a strong secret: `openssl rand -hex 32`
JWT_SECRET_KEY=replace_this_with_a_64_character_random_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- App ----
APP_ENV=development
APP_NAME=ScholarPath AI
FRONTEND_ORIGIN=http://localhost:5173
ADMIN_SEED_EMAIL=admin@scholarpath.ai
ADMIN_SEED_PASSWORD=ChangeMe123!
